#!/bin/bash
set -e

# --- Rebase guard: skip during rebase/merge/cherry-pick ---
if [ -d "$(git rev-parse --git-dir)/rebase-merge" ] || \
   [ -d "$(git rev-parse --git-dir)/rebase-apply" ] || \
   [ -f "$(git rev-parse --git-dir)/MERGE_HEAD" ] || \
   [ -f "$(git rev-parse --git-dir)/CHERRY_PICK_HEAD" ]; then
    echo "Rebase/merge/cherry-pick in progress, skipping pre-commit hook."
    exit 0
fi

# Get list of staged PHP files
STAGED_PHP_FILES=$(git diff --cached --name-only --diff-filter=d | grep '\.php$' || true)

if [ -z "$STAGED_PHP_FILES" ]; then
    echo "No PHP files staged, skipping quality checks."
    exit 0
fi

# --- Safety: save staged changes as a patch for recovery ---
PATCH_DIR="$(git rev-parse --git-dir)/hook-patches"
mkdir -p "$PATCH_DIR"
PATCH_FILE="$PATCH_DIR/pre-commit-$(date +%Y%m%d-%H%M%S).patch"

git diff --cached > "$PATCH_FILE"
if [ ! -s "$PATCH_FILE" ]; then
    rm -f "$PATCH_FILE"
else
    echo "Staged changes saved to: $PATCH_FILE"
    echo "(Restore with: git apply $PATCH_FILE)"
fi

# --- Quality checks ---
echo "Running quality checks on staged PHP files..."

# ECS check
echo "-> ECS check..."
if ! docker compose exec -T php vendor/bin/ecs check $STAGED_PHP_FILES; then
    echo ""
    echo "ECS failed. Your staged changes are safe in: $PATCH_FILE"
    exit 1
fi

# PHPStan
echo "-> PHPStan..."
if ! docker compose exec -T php vendor/bin/phpstan analyse --memory-limit=512M $STAGED_PHP_FILES; then
    echo ""
    echo "PHPStan failed. Your staged changes are safe in: $PATCH_FILE"
    exit 1
fi

# Rector dry-run
echo "-> Rector dry-run..."
if ! docker compose exec -T php vendor/bin/rector process --dry-run $STAGED_PHP_FILES; then
    echo ""
    echo "Rector failed. Your staged changes are safe in: $PATCH_FILE"
    exit 1
fi

# All passed -- clean up the patch (no longer needed)
rm -f "$PATCH_FILE"
echo "All quality checks passed!"
